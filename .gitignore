# Gradle files
.gradle/
build/
app/build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Gradle
app/proguard/

# Log Files
*.log

# Android Studio / IntelliJ IDEA files
.idea/
*.iml
*.ipr
*.iws
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches

# Keystore files
# Uncomment these if you use a local keystore
# *.jks
# *.keystore

# Google Services (Firebase)
# google-services.json

# Android App Bundle / APK
*.apk
*.apks
*.aab

# OS generated files
.DS_Store
Thumbs.db

# Captures
captures/

# External Native Build
.externalNativeBuild
.cxx/

# Lint
lint/
build/

# Signing
# It's better to keep signing files out of version control
# *.jks
# *.p12
# *.pem
# *.der
# *.pfx

# Others
_key*
*.bak
*.swp
*~
.DS_Store
